# ─── Delivery Sync — Function Environment Variables ─────────────────────────
# Copy .env.example → .env and fill in your values.
# Also copy these into:
#   Catalyst Console → Functions → delivery_sync_function
#   → Configuration → Environment Variables  (required for production)

# ─── Email ───────────────────────────────────────────────────────────────────
FROM_EMAIL=noreply@yourdomain.com

# ─── Catalyst Role IDs ───────────────────────────────────────────────────────
# Catalyst Console → your app → User Management → App Users → Roles
CATALYST_ROLE_TENANT_ADMIN=
CATALYST_ROLE_DELIVERY_LEAD=
CATALYST_ROLE_TEAM_MEMBER=
CATALYST_ROLE_PMO=
CATALYST_ROLE_EXEC=
CATALYST_ROLE_CLIENT=
CATALYST_ROLE_SUPER_ADMIN=

# ─── App Base URL ────────────────────────────────────────────────────────────
# Development:  https://<project>.development.catalystserverless.in/app
# Production:   https://<your-custom-domain>/app
APP_BASE_URL=

# ─── Stratus Bucket URLs ─────────────────────────────────────────────────────
# Catalyst Console → File Store → Buckets → user-avatars → copy the base URL
STRATUS_USER_AVATARS_URL=
