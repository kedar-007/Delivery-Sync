# ─── Catalyst / Zoho Configuration ───────────────────────────────────────────
# Automatically injected by Catalyst runtime — only needed for local dev
CATALYST_PROJECT_ID=
CATALYST_ENV=development

# ─── Stratus Object Storage ───────────────────────────────────────────────────
# Pattern: https://<bucket-name>-development.zohostratus.in  (dev)
#          https://<bucket-name>.zohostratus.in              (prod)

# delivery_sync_function — user avatars
STRATUS_BUCKET_NAME=profiles-users
STRATUS_USER_AVATARS_URL=https://profiles-users-development.zohostratus.in

# task_sprint_service — task attachments
STRATUS_ATTACHMENTS_BUCKET=task-attachments
STRATUS_ATTACHMENTS_URL=https://task-attachments-development.zohostratus.in

# ─── Email / Notification ─────────────────────────────────────────────────────
FROM_EMAIL=noreply@yourorg.com

# ─── App URL ──────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.development.catalystserverless.in/app
